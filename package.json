{
  "name": "tachyon-rs",
  "version": "1.0.0",
  "description": "Template project for writing node package with napi-rs",
  "workspaces": ["tachyon-library", "tachyon-napi"],
  "scripts": {
    "artifacts": "napi artifacts",
    "bench": "node --import @oxc-node/core/register benchmark/bench.ts",
    "examples": "cd tachyon-napi && bun run example/server.ts",
    "build": "cd tachyon-napi && napi build --platform --release",
    "build:debug": "cd tachyon-napi && napi build --platform",
    "format": "run-p format:prettier format:rs format:toml",
    "format:prettier": "prettier . -w",
    "format:toml": "taplo format",
    "format:rs": "cargo fmt",
    "lint": "oxlint .",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "cd tachyon-napi && ava",
    "preversion": "napi build --platform && git add .",
    "version": "napi version",
    "prepare": "husky"
  }
}
