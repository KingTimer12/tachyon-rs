  "scripts": {
    "build": "bun build src/index.ts --outdir dist --format esm --minify --external @tachyon-rs/server && tsc"
  },
  "dependencies": {
    "@tachyon-rs/server": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "version": "0.2.7"
}
